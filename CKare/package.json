{
  "name": "site-creator-vinext-starter",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "overrides": {
    "sharp": "0.35.3",
    "ws": "8.21.1"
  },
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "vinext dev",
    "build": "vinext build",
    "start": "vinext start",
    "start:pro": "npm --prefix apps/ckare-pro run start",
    "start:care": "npm --prefix apps/ckare-care run start",
    "test": "node --test tests/*.test.mjs",
    "test:web-build": "npm run build",
    "typecheck:pro": "npm --prefix apps/ckare-pro run typecheck",
    "typecheck:care": "npm --prefix apps/ckare-care run typecheck",
    "doctor:pro": "npm --prefix apps/ckare-pro run doctor",
    "doctor:care": "npm --prefix apps/ckare-care run doctor",
    "lint": "eslint . --ignore-pattern dist --ignore-pattern .next",
    "db:generate": "drizzle-kit generate"
  },
  "dependencies": {
    "drizzle-orm": "0.45.2",
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.37.1",
    "@tailwindcss/postcss": "4.2.1",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitejs/plugin-rsc": "0.5.26",
    "drizzle-kit": "0.31.10",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "jsdom": "^29.1.1",
    "react-server-dom-webpack": "19.2.6",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3",
    "vinext": "0.0.50",
    "vite": "8.0.13",
    "wrangler": "4.92.0"
  },
  "type": "module"
}
